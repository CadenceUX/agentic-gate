{
  "version": 1,
  "environments": {
    "pack-a": {
      "description": "Your own skill pack (rename this key and describe your skills)",
      "skills": ["pack-a:*"],
      "paths": ["*/skills-plugin/*"]
    },
    "vendor-x": {
      "description": "A third-party vendor plugin (its agents, reference catalog, build tooling)",
      "skills": ["VendorX:*"],
      "agents": ["VendorX:*"],
      "commands": [
        "vx-build", "vx-patch-runner", "vx-slot-fill", "vx-export",
        "vx-admin", "vx-query", "vx-addon-build", "vx-script-bridge",
        "vx-solution-init", "vx-standards-resolve", "vx-diff"
      ],
      "paths": ["~/.claude/plugins/cache/vendor-x/*"]
    },
    "vendor-y": {
      "description": "Another skill pack and MCP server",
      "skills": ["vendor-y:*"],
      "mcp": ["mcp__vendor-y__*"]
    },
    "vendor-z": {
      "description": "A third skill pack and MCP server",
      "skills": ["vendor-z:*"],
      "mcp": ["mcp__vendor-z__*"]
    }
  },
  "shared": {
    "description": "Delivery utilities every environment may use (clipboard writes, previews)",
    "commands": ["vx-clipboard-write", "vx-clipboard-decode", "vx-renderer", "vx-calc-write"]
  },
  "policy": {
    "default": "warn",
    "unknown": "warn",
    "pairs": {
      "vendor-y|vendor-z": "gate"
    }
  },
  "projects": {
    "/path/to/your/project": "vendor-x"
  }
}
